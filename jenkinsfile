pipeline {
    agent {
  label 'Devserver'
}

    }

    stages {
        stage('Build') {
            steps {
                echo "Building the application..."
                sh 'mvn clean package'
            }

            post {
                success {
                    echo "Build successful!"
                }
                failure {
                    echo "Build failed!"
                }
            }
        }
        stage('Test') {
            steps {
                echo "Running tests..."
                sh 'mvn test'
            }
        }
        stage('Deploy') {
            steps {
                echo "Deploying the application..."
                // Add deployment steps here
            }
        }
    }
}